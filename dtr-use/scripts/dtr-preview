#!/usr/bin/env bash
# dtr-preview — Preview a DTR node's cached output and save to a temp file.
# Usage: scripts/dtr-preview [target]
#   target: node ID (e.g. n4) or marker name. Defaults to current node.
#
# Output is saved to /tmp/dtr-preview-output.png (for charts)
# or /tmp/dtr-preview-output.txt (for text/table output).
# The file path is printed on the last line.

set -euo pipefail

SKILL_DIR="$(cd "$(dirname "$0")/.." && pwd)"
TARGET="${1:-}"

OUT_FILE_PNG="/tmp/dtr-preview-output.png"
OUT_FILE_TXT="/tmp/dtr-preview-output.txt"

rm -f "$OUT_FILE_PNG" "$OUT_FILE_TXT"

if [ -n "$TARGET" ]; then
  dtr preview "$TARGET" > "$OUT_FILE_PNG" 2>/dev/null || true
else
  dtr preview > "$OUT_FILE_PNG" 2>/dev/null || true
fi

# Check if output is a PNG
if file "$OUT_FILE_PNG" | grep -q "PNG image"; then
  echo "IMAGE:$OUT_FILE_PNG"
else
  mv "$OUT_FILE_PNG" "$OUT_FILE_TXT"
  echo "TEXT:$OUT_FILE_TXT"
fi
